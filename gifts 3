PAGE_SIZE = 5


@router.callback_query(F.data.startswith("filter_list_"))
async def cb_filter_list(cb: CallbackQuery):
    parts = cb.data.split("_")
    # filter_list_{type}_{page}
    filter_type = parts[2]
    page = int(parts[3]) if len(parts) > 3 else 0

    filters = await get_filters(cb.from_user.id, filter_type)
    if not filters:
        await cb.message.edit_text(
            "📭 У тебя пока нет фильтров этого типа.",
            reply_markup=InlineKeyboardMarkup(inline_keyboard=[
                [InlineKeyboardButton(text="◀️ Назад", callback_data=f"menu_{'listings' if filter_type == 'listing' else 'sales'}")]
            ])
        )
        await cb.answer()
        return

    total = len(filters)
    start = page * PAGE_SIZE
    end = min(start + PAGE_SIZE, total)
    page_filters = filters[start:end]

    lines = [f"📋 <b>Фильтры {'листингов' if filter_type == 'listing' else 'продаж'}</b> ({total})\n"]
    buttons = []
    for f in page_filters:
        parts_info = []
        if f.get("model"):
            parts_info.append(f['model'])
        if f.get("price_to"):
            parts_info.append(f"до {f['price_to']} TON")
        label = f.get("name") or (" · ".join(parts_info) if parts_info else f"Фильтр #{f['id']}")
        lines.append(f"• <b>{label}</b> #{f['id']}")
        buttons.append([InlineKeyboardButton(
            text=f"🗑 Удалить #{f['id']} — {label[:20]}",
            callback_data=f"filter_del_{f['id']}_{filter_type}"
        )])

    # Pagination
    nav = []
    if page > 0:
        nav.append(InlineKeyboardButton(text="◀️", callback_data=f"filter_list_{filter_type}_{page-1}"))
    if end < total:
        nav.append(InlineKeyboardButton(text="▶️", callback_data=f"filter_list_{filter_type}_{page+1}"))
    if nav:
        buttons.append(nav)

    buttons.append([InlineKeyboardButton(text="◀️ Назад", callback_data=f"menu_{'listings' if filter_type == 'listing' else 'sales'}")])

    await cb.message.edit_text(
        "\n".join(lines), parse_mode="HTML",
        reply_markup=InlineKeyboardMarkup(inline_keyboard=buttons)
    )
    await cb.answer()


@router.callback_query(F.data.startswith("filter_del_"))
async def cb_filter_delete(cb: CallbackQuery):
    parts = cb.data.split("_")
    filter_id = int(parts[2])
    filter_type = parts[3]

    deleted = await delete_filter(filter_id, cb.from_user.id)
    if deleted:
        await cb.answer(f"✅ Фильтр #{filter_id} удалён.", show_alert=False)
    else:
        await cb.answer("❌ Фильтр не найден.", show_alert=True)

    # Refresh list
    filters = await get_filters(cb.from_user.id, filter_type)
    if not filters:
        await cb.message.edit_text(
            "📭 Фильтров не осталось.",
            reply_markup=InlineKeyboardMarkup(inline_keyboard=[
                [InlineKeyboardButton(text="◀️ В меню", callback_data="menu_main")]
            ])
        )
        return

    # Re-render first page
    from aiogram.types import InlineKeyboardMarkup, InlineKeyboardButton
    await cb.message.edit_reply_markup(reply_markup=InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="🔄 Обновить список", callback_data=f"filter_list_{filter_type}_0")],
        [InlineKeyboardButton(text="◀️ В меню", callback_data="menu_main")],
    ]))

