from aiogram import Router, F
from aiogram.types import CallbackQuery, InlineKeyboardMarkup, InlineKeyboardButton

from middleware import AccessMiddleware
from db.database import get_blocked_gifts, unblock_gift, block_gift

router = Router()
router.callback_query.middleware(AccessMiddleware())

PAGE_SIZE = 8


@router.callback_query(F.data == "menu_blocked")
async def cb_menu_blocked(cb: CallbackQuery):
    await show_blocked(cb, page=0)


@router.callback_query(F.data.startswith("blocked_page_"))
async def cb_blocked_page(cb: CallbackQuery):
    page = int(cb.data.split("_")[2])
    await show_blocked(cb, page=page)


async def show_blocked(cb: CallbackQuery, page: int):
    blocked = await get_blocked_gifts(cb.from_user.id)

    if not blocked:
        await cb.message.edit_text(
            "🚫 <b>Заблокированные подарки</b>\n\nСписок пуст.",
            parse_mode="HTML",
            reply_markup=InlineKeyboardMarkup(inline_keyboard=[
                [InlineKeyboardButton(text="◀️ Назад", callback_data="menu_main")]
            ])
        )
        await cb.answer()
        return

    total = len(blocked)
    start = page * PAGE_SIZE
    end = min(start + PAGE_SIZE, total)
    page_items = blocked[start:end]

    lines = [f"🚫 <b>Заблокированных подарков: {total}</b>\n"]
    buttons = []
    for item in page_items:
        label = f"{item['gift_id']} ({item['marketplace']})"
        lines.append(f"• {label}")
        buttons.append([InlineKeyboardButton(
            text=f"✅ Разблокировать {item['gift_id'][:15]}",
            callback_data=f"unblock_{item['gift_id']}_{item['marketplace']}"
        )])

    nav = []
    if page > 0:
        nav.append(InlineKeyboardButton(text="◀️", callback_data=f"blocked_page_{page-1}"))
    if end < total:
        nav.append(InlineKeyboardButton(text="▶️", callback_data=f"blocked_page_{page+1}"))
    if nav:
        buttons.append(nav)

    buttons.append([InlineKeyboardButton(text="◀️ Назад", callback_data="menu_main")])

    await cb.message.edit_text(
        "\n".join(lines), parse_mode="HTML",
        reply_markup=InlineKeyboardMarkup(inline_keyboard=buttons)
    )
    await cb.answer()


@router.callback_query(F.data.startswith("unblock_"))
async def cb_unblock(cb: CallbackQuery):
    # unblock_{gift_id}_{marketplace}
    parts = cb.data.split("_", 2)
    gift_id = parts[1]
    marketplace = parts[2]
    await unblock_gift(cb.from_user.id, gift_id, marketplace)
    await cb.answer(f"✅ {gift_id} разблокирован!", show_alert=False)
    await show_blocked(cb, page=0)


@router.callback_query(F.data.startswith("blockgift_"))
async def cb_block_gift(cb: CallbackQuery):
    # blockgift_{gift_id}_{marketplace}  — called from notification
    parts = cb.data.split("_", 2)
    gift_id = parts[1]
    marketplace = parts[2]
    await block_gift(cb.from_user.id, gift_id, marketplace)
    await cb.answer(f"🚫 Подарок {gift_id} заблокирован. Уведомлений больше не будет.", show_alert=True)
    try:
        await cb.message.edit_reply_markup(reply_markup=None)
    except Exception:
        pass

from aiogram import Router, F
from aiogram.types import Message, CallbackQuery, InlineKeyboardMarkup, InlineKeyboardButton
from aiogram.fsm.context import FSMContext
from aiogram.fsm.state import State, StatesGroup

from middleware import AccessMiddleware
from db.database import add_filter, get_filters, delete_filter, get_filter_count
from config import MAX_FILTERS

router = Router()
router.message.middleware(AccessMiddleware())
router.callback_query.middleware(AccessMiddleware())


class AddFilterFSM(StatesGroup):
    filter_type = State()
    model = State()
    background = State()
    number_from = State()
    number_to = State()
    price_from = State()
    price_to = State()
    marketplace = State()
    name = State()


def filters_menu_kb(filter_type: str) -> InlineKeyboardMarkup:
