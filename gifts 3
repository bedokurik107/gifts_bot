# ── ADD FILTER FSM ────────────────────────────────────────────────────────────

@router.callback_query(F.data.in_({"filter_add_listing", "filter_add_sale"}))
async def cb_filter_add(cb: CallbackQuery, state: FSMContext):
    filter_type = "listing" if "listing" in cb.data else "sale"
    count = await get_filter_count(cb.from_user.id)
    if count >= MAX_FILTERS:
        await cb.answer(f"❌ Лимит {MAX_FILTERS} фильтров достигнут!", show_alert=True)
        return

    await state.set_state(AddFilterFSM.model)
    await state.update_data(filter_type=filter_type)
    await cb.message.edit_text(
        "🎁 <b>Новый фильтр</b>\n\n"
        "Шаг 1/6 — Введи <b>название модели</b> подарка (например: <code>Plush Pepe</code>)\n"
        "или пропусти этот шаг.",
        parse_mode="HTML",
        reply_markup=skip_kb()
    )
    await cb.answer()


@router.callback_query(F.data == "skip_step", AddFilterFSM.model)
@router.message(AddFilterFSM.model)
async def fsm_model(event, state: FSMContext):
    if isinstance(event, Message):
        await state.update_data(model=event.text.strip())
    else:
        await state.update_data(model=None)
        event = event.message

    await state.set_state(AddFilterFSM.background)
    await event.answer(
        "Шаг 2/6 — Введи <b>фон</b> подарка (например: <code>Blue</code>)\n"
        "или пропусти.",
        parse_mode="HTML",
        reply_markup=skip_kb()
    )


@router.callback_query(F.data == "skip_step", AddFilterFSM.background)
@router.message(AddFilterFSM.background)
async def fsm_background(event, state: FSMContext):
    if isinstance(event, Message):
        await state.update_data(background=event.text.strip())
    else:
        await state.update_data(background=None)
        event = event.message

    await state.set_state(AddFilterFSM.number_from)
    await event.answer(
        "Шаг 3/6 — Введи <b>минимальный номер</b> подарка (например: <code>1</code>)\n"
        "или пропусти.",
        parse_mode="HTML",
        reply_markup=skip_kb()
    )


@router.callback_query(F.data == "skip_step", AddFilterFSM.number_from)
@router.message(AddFilterFSM.number_from)
async def fsm_number_from(event, state: FSMContext):
    if isinstance(event, Message):
        try:
            await state.update_data(number_from=int(event.text.strip()))
        except ValueError:
            await event.answer("❌ Введи число или пропусти.", reply_markup=skip_kb())
            return
    else:
        await state.update_data(number_from=None)
        event = event.message

    await state.set_state(AddFilterFSM.number_to)
    await event.answer(
        "Шаг 4/6 — Введи <b>максимальный номер</b> подарка\n"
        "или пропусти.",
        parse_mode="HTML",
        reply_markup=skip_kb()
    )


@router.callback_query(F.data == "skip_step", AddFilterFSM.number_to)
@router.message(AddFilterFSM.number_to)
async def fsm_number_to(event, state: FSMContext):
