@router.callback_query(F.data == "skip_step", AddFilterFSM.price_to)
@router.message(AddFilterFSM.price_to)
async def fsm_price_to(event, state: FSMContext):
    if isinstance(event, Message):
        try:
            await state.update_data(price_to=float(event.text.strip().replace(",", ".")))
        except ValueError:
            await event.answer("❌ Введи число или пропусти.", reply_markup=skip_kb())
            return
    else:
        await state.update_data(price_to=None)
        event = event.message

    await state.set_state(AddFilterFSM.marketplace)
    await event.answer(
        "Выбери <b>маркетплейс</b> для мониторинга:",
        parse_mode="HTML",
        reply_markup=marketplace_kb()
    )


@router.callback_query(F.data.startswith("mp_"), AddFilterFSM.marketplace)
async def fsm_marketplace(cb: CallbackQuery, state: FSMContext):
    mp = cb.data.replace("mp_", "")
    await state.update_data(marketplace=mp)
    await state.set_state(AddFilterFSM.name)
    await cb.message.edit_text(
        "Введи <b>название</b> для этого фильтра (для удобства)\n"
        "или пропусти — назову автоматически.",
        parse_mode="HTML",
        reply_markup=skip_kb()
    )
    await cb.answer()


@router.callback_query(F.data == "skip_step", AddFilterFSM.name)
@router.message(AddFilterFSM.name)
async def fsm_name_done(event, state: FSMContext):
    data = await state.get_data()
    if isinstance(event, Message):
        data["name"] = event.text.strip()
    else:
        # Auto-generate name
        parts = []
        if data.get("model"):
            parts.append(data["model"])
        if data.get("price_to"):
            parts.append(f"до {data['price_to']} TON")
        data["name"] = " · ".join(parts) if parts else "Фильтр"
        event = event.message

    filter_id = await add_filter(event.from_user.id, data["filter_type"], data)
    await state.clear()

    if filter_id is None:
        await event.answer("❌ Лимит фильтров достигнут!")
        return

    # Build summary
    lines = [f"✅ <b>Фильтр добавлен!</b> (#{filter_id})\n", f"📌 Название: <b>{data['name']}</b>"]
    if data.get("model"):
        lines.append(f"🎁 Модель: {data['model']}")
    if data.get("background"):
        lines.append(f"🎨 Фон: {data['background']}")
    if data.get("number_from") or data.get("number_to"):
        nf = data.get("number_from", "—")
        nt = data.get("number_to", "—")
        lines.append(f"🔢 Номер: {nf} – {nt}")
    if data.get("price_from") or data.get("price_to"):
        pf = data.get("price_from", "—")
        pt = data.get("price_to", "—")
        lines.append(f"💰 Цена: {pf} – {pt} TON")
    lines.append(f"🌐 Маркетплейс: {data.get('marketplace', 'all')}")

    kb = InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="◀️ В меню", callback_data="menu_main")]
    ])
    await event.answer("\n".join(lines), parse_mode="HTML", reply_markup=kb)


