        [InlineKeyboardButton(text="➕ Добавить фильтр", callback_data=f"filter_add_{filter_type}")],
        [InlineKeyboardButton(text="📋 Мои фильтры", callback_data=f"filter_list_{filter_type}_0")],
        [InlineKeyboardButton(text="◀️ Назад", callback_data="menu_main")],
    ])


def marketplace_kb() -> InlineKeyboardMarkup:
    return InlineKeyboardMarkup(inline_keyboard=[
        [
            InlineKeyboardButton(text="🌐 Все", callback_data="mp_all"),
            InlineKeyboardButton(text="GetGems", callback_data="mp_getgems"),
        ],
        [
            InlineKeyboardButton(text="Tonnel", callback_data="mp_tonnel"),
            InlineKeyboardButton(text="Portals", callback_data="mp_portals"),
        ],
        [InlineKeyboardButton(text="MRKT", callback_data="mp_mrkt")],
    ])


def skip_kb() -> InlineKeyboardMarkup:
    return InlineKeyboardMarkup(inline_keyboard=[
